# ENSO Intelligence Platform — credential template.
# Copy to `.env` and fill in. Loaded via python-dotenv. NEVER commit `.env`.
# All Phase 1 sources (ONI, Pink Sheet, advisory) are free and need NO keys.
# These are only required for Phase 2 data sources.

# Copernicus Climate Data Store (ERA5 SST grids) — register at
# https://cds.climate.copernicus.eu/  (key also goes in ~/.cdsapirc)
CDSAPI_URL=https://cds.climate.copernicus.eu/api
CDSAPI_KEY=

# USDA NASS Quick Stats (US crop yields) — free key at
# https://quickstats.nass.usda.gov/api
USDA_NASS_API_KEY=

# EM-DAT disaster database — account + data request at https://www.emdat.be/
EMDAT_USERNAME=
EMDAT_PASSWORD=
